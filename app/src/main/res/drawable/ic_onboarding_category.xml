        android:fillColor="#9B7FFF"
        android:pathData="M47,42 L52,47 L57,47 L57,42 Q57,40 55,42 Z"
        android:alpha="0.7" />

    <!-- Plus sign for adding category -->
    <g>
        <!-- Horizontal line -->
        <rect
            android:left="53"
            android:top="62"
            android:right="67"
            android:bottom="65"
            android:rx="1.5"
            android:ry="1.5"
            android:fillColor="#FFFFFF" />

        <!-- Vertical line -->
        <rect
            android:left="59"
            android:top="56"
            android:right="62"
            android:bottom="72"
            android:rx="1.5"
            android:ry="1.5"
            android:fillColor="#FFFFFF" />
    </g>

    <!-- Folder shine -->
    <rect
        android:left="30"
        android:top="50"
        android:right="90"
        android:bottom="54"
        android:rx="3"
        android:fillColor="#FFFFFF"
        android:alpha="0.2" />
</vector>
