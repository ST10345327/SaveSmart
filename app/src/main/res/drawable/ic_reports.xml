<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Chart background/border -->
    <rect
        android:left="2"
        android:top="3"
        android:right="22"
        android:bottom="20"
        android:rx="2"
        android:ry="2"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A6FE8"
        android:strokeWidth="1.2" />

    <!-- Horizontal grid line -->
    <line
        android:startX="2"
        android:startY="11"
        android:endX="22"
        android:endY="11"
        android:strokeColor="#1A6FE8"
        android:strokeWidth="0.8"
        android:alpha="0.2" />

    <!-- Bar chart columns -->
    <!-- Column 1 -->
    <rect
        android:left="5"
        android:top="13"
        android:right="8"
        android:bottom="18"
        android:rx="1"
        android:ry="1"
        android:fillColor="#1A6FE8"
        android:alpha="0.6" />

    <!-- Column 2 (tallest) -->
    <rect
        android:left="10"
        android:top="8"
        android:right="13"
        android:bottom="18"
        android:rx="1"
        android:ry="1"
        android:fillColor="#1A6FE8" />

    <!-- Column 3 -->
    <rect
        android:left="15"
        android:top="11"
        android:right="18"
        android:bottom="18"
        android:rx="1"
        android:ry="1"
        android:fillColor="#1A6FE8"
        android:alpha="0.7" />

    <!-- Trend line indicator (going up) -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M 8,13 L 13,8 L 18,11"
        android:strokeColor="#2DBF60"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Trend arrow -->
    <path
        android:fillColor="#2DBF60"
        android:pathData="M 18,11 L 16.5,9.5 L 17.5,8" />
</vector>